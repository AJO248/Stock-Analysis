# AI-Powered Stock Analysis Platform - Environment Configuration
# Copy this file to .env and fill in your API keys

# OpenAI API Key (required for summarization and RAG)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI API Base URL (optional - for custom endpoints)
# Default: https://api.openai.com/v1
# For Azure OpenAI, local LLMs, or other compatible APIs
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Model selection
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: API rate limit settings
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT=60

# News scraping settings
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36
SCRAPING_DELAY=1.5

# Cache settings (in seconds)
STOCK_CACHE_DURATION=300
NEWS_CACHE_DURATION=3600
SUMMARY_CACHE_DURATION=86400

# Database
DB_PATH=./data/news_cache.db
VECTOR_STORE_PATH=./data/vector_store/
